        "background-size": "cover",
        "opacity": 20
      },
      "styles": [{}, {}, {}],
      "images": [
        "https://endfield.wiki.gg/images/Snapshot_Estella_3.png?f01d11",
      ],
      "interval": 0,
      "random": false
    },

